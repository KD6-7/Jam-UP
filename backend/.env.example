# Neon connection string, e.g.:
# postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Comma-separated list of allowed CORS origins, e.g.:
# https://your-app.vercel.app,http://localhost:3000
FRONTEND_ORIGIN=

# OAuth 2.0 Client ID from Google Cloud Console (Web application type)
GOOGLE_CLIENT_ID=

# Long random string used to sign session tokens, e.g. `openssl rand -hex 32`
JWT_SECRET=
