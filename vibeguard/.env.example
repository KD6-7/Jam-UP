# --- Upstream LLM provider (OpenAI-compatible) ---
VIBEGUARD_UPSTREAM_URL=https://api.openai.com
# If set, VibeGuard uses this key upstream; otherwise it forwards the caller's
# Authorization header unchanged.
VIBEGUARD_UPSTREAM_API_KEY=
VIBEGUARD_UPSTREAM_TIMEOUT=60

# --- Token mapping store ---
# Leave blank to use the in-memory store (single process, dev only).
VIBEGUARD_REDIS_URL=
VIBEGUARD_TOKEN_TTL=600

# --- Semantic injection firewall ---
VIBEGUARD_ENABLE_SEMANTIC=1
# Set to 0 to force the dependency-free bag-of-words fallback.
VIBEGUARD_PREFER_ST_MODEL=1
VIBEGUARD_EMBEDDING_MODEL=all-MiniLM-L6-v2
VIBEGUARD_INJECTION_THRESHOLD=0.85

# --- Rate limiting (token bucket) ---
VIBEGUARD_RATE_LIMIT=0
VIBEGUARD_RATE_LIMIT_CAPACITY=60
VIBEGUARD_RATE_LIMIT_REFILL=1

# --- Custom PII blocklist (comma-separated named entities) ---
VIBEGUARD_BLOCKLIST=
